{
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/server.js"
    },
    {
      "source": "/assets/:path*",
      "destination": "frontend/dist/assets/:path*"
    },
    {
      "source": "/:path*",
      "destination": "frontend/dist/index.html"
    }
  ]
}

