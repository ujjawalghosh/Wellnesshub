{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/dist/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "destination": "/backend/server.js"
    },
    {
      "src": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
